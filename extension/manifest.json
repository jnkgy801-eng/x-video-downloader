{
  "manifest_version": 3,
  "name": "X動画自動ダウンローダー",
  "version": "1.0.0",
  "description": "X (Twitter) で閲覧した動画を自動でローカルに保存します",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://localhost:5566/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "X動画ダウンローダー"
  }
}
